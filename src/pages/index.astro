---
import '../styles/global.css'
import WorkflowDiagram from '../components/WorkflowDiagram'
import ContextRot from '../components/ContextRot'
import SkillSection from '../components/SkillSection'
import HeroSection from '../components/HeroSection'
import { grillMe, writeAPrd, prdToPlan, planToTracker, doWork, improveCodebaseArchitecture, handleCoderabbit } from '../data/skills'
---

<html lang="pt-BR">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>SkillForge — Workflow profissional de AI coding</title>
		<meta name="description" content="Pare de fazer vibe coding. Tenha um workflow profissional de desenvolvimento assistido por IA — da concepção ao code review." />
		<meta name="theme-color" content="#0a0a0a" />
	</head>
	<body class="bg-neutral-950 text-neutral-100 scroll-smooth">

		<header id="hero" class="min-h-[100dvh] flex flex-col items-center justify-center px-4 sm:px-6 text-center">
			<HeroSection client:load />
		</header>

		<section id="workflow" class="min-h-screen px-4 sm:px-6 py-16 sm:py-24 max-w-6xl mx-auto">
			<h2 class="text-3xl sm:text-4xl font-bold text-center mb-4">O Workflow</h2>
			<p class="text-neutral-400 text-center max-w-2xl mx-auto mb-12 sm:mb-16">
				7 skills que transformam o uso da IA em um processo disciplinado e reproduzível.
			</p>
			<WorkflowDiagram client:only="react" />
		</section>

		<section id="context-rot" class="px-4 sm:px-6 py-16 sm:py-24 max-w-4xl mx-auto">
			<ContextRot client:visible />
		</section>

		<section id="skill-grill-me" class="px-4 sm:px-6 py-16 sm:py-24 max-w-4xl mx-auto">
			<SkillSection {...grillMe} client:visible />
		</section>

		<section id="skill-write-a-prd" class="px-4 sm:px-6 py-16 sm:py-24 max-w-4xl mx-auto">
			<SkillSection {...writeAPrd} client:visible />
		</section>

		<section id="skill-prd-to-plan" class="px-4 sm:px-6 py-16 sm:py-24 max-w-4xl mx-auto">
			<SkillSection {...prdToPlan} client:visible />
		</section>

		<section id="skill-plan-to-tracker" class="px-4 sm:px-6 py-16 sm:py-24 max-w-4xl mx-auto">
			<SkillSection {...planToTracker} client:visible />
		</section>

		<section id="skill-do-work" class="px-4 sm:px-6 py-16 sm:py-24 max-w-4xl mx-auto">
			<SkillSection {...doWork} client:visible />
		</section>

		<section id="skill-improve-codebase-architecture" class="px-4 sm:px-6 py-16 sm:py-24 max-w-4xl mx-auto">
			<SkillSection {...improveCodebaseArchitecture} client:visible />
		</section>

		<section id="skill-handle-coderabbit" class="px-4 sm:px-6 py-16 sm:py-24 max-w-4xl mx-auto">
			<SkillSection {...handleCoderabbit} client:visible />
		</section>

		<footer class="px-4 sm:px-6 py-12 sm:py-16 border-t border-neutral-800">
			<div class="max-w-4xl mx-auto text-center space-y-4">
				<p class="text-sm uppercase tracking-widest text-emerald-400 font-mono">SkillForge</p>
				<p class="text-neutral-500 text-sm">
					Workflow profissional de desenvolvimento assistido por IA.
				</p>
				<nav class="flex items-center justify-center gap-6 text-sm text-neutral-600">
					<a href="#hero" class="hover:text-neutral-300 transition-colors">Topo</a>
					<a href="#workflow" class="hover:text-neutral-300 transition-colors">Workflow</a>
					<a href="#context-rot" class="hover:text-neutral-300 transition-colors">Context Rot</a>
				</nav>
			</div>
		</footer>

	</body>
</html>
